# Copie ce fichier en .env et charge-le (ex: `export $(cat .env | xargs)`) pour
# lancer le backend en local sans Docker, hors déploiement Render.

# Génère une valeur avec: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change_me_dev_only

# Génère une valeur avec: python -c "import secrets; print(secrets.token_urlsafe(32))"
SERVER_SECRET_KEY=change_me_dev_only

# Laisse vide pour utiliser SQLite en local (backend/roso_dev.db)
# DATABASE_URL=postgresql://user:password@localhost:5432/roso

CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
